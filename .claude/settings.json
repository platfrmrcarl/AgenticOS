{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ci)",
      "Bash(npm list:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(tsc:*)",
      "Bash(tsx:*)",
      "Bash(node:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(next:*)",
      "Bash(next build)",
      "Bash(next dev)",
      "Bash(next lint)",
      "Bash(gcloud config:*)",
      "Bash(gcloud projects list)",
      "Bash(gcloud auth list)",
      "Bash(gcloud logging read:*)",
      "Bash(gcloud run services list:*)",
      "Bash(gcloud run services describe:*)",
      "Bash(stripe listen:*)",
      "Bash(stripe logs tail:*)",
      "Bash(stripe events:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(gcloud run deploy:*)",
      "Bash(gcloud functions deploy:*)",
      "Bash(gcloud builds submit:*)",
      "Bash(gcloud iam:*)",
      "Bash(gcloud secrets:*)",
      "Bash(stripe products:*)",
      "Bash(stripe prices:*)",
      "Bash(stripe subscriptions:*)",
      "Bash(npm publish:*)",
      "Bash(npm version:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(gcloud projects delete:*)",
      "Bash(gcloud run services delete:*)",
      "Bash(gcloud sql instances delete:*)",
      "Bash(gcloud iam service-accounts delete:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/serviceAccountKey.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(stripe products delete:*)",
      "Bash(stripe prices delete:*)"
    ],
    "enabledPlugins": {
      "andrej-karpathy-skills@karpathy-skills": true
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',d).get('command',''))\" 2>/dev/null || true); case \"$CMD\" in *grep*|*rg\\ *|*ripgrep*|*find\\ *|*fd\\ *|*ack\\ *|*ag\\ *)   [ -f graphify-out/graph.json ] &&   echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}'   || true ;; esac"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "~/.claude/projects/platfrmr/memory"
}